---
const eventTypes = [
  {
    icon: '&#x1F3E2;',
    title: 'Corporate Lunch',
    subtitle: "Elevate your team's lunch with gourmet sliders",
    value: 'Corporate Lunch',
    photo: '/assets/imported/ig-goldwater.jpg',
  },
  {
    icon: '&#x1F389;',
    title: 'Private Party',
    subtitle: 'Birthday, anniversary, or just because',
    value: 'Private Party',
    photo: '/assets/imported/ig-sliders-rack.jpg',
  },
  {
    icon: '&#x1F37A;',
    title: 'Brewery/Taproom',
    subtitle: 'Perfect pairing: craft beer + craft sliders',
    value: 'Brewery/Taproom',
    photo: '/assets/imported/yelp-photo.jpg',
  },
  {
    icon: '&#x1F492;',
    title: 'Wedding/Celebration',
    subtitle: 'Make your special day deliciously memorable',
    value: 'Wedding/Celebration',
    photo: '/assets/imported/ig-food-carousel.jpg',
  },
  {
    icon: '&#x1F3EB;',
    title: 'School/Community',
    subtitle: 'Fundraisers, festivals, and community events',
    value: 'School/Community',
    photo: '/assets/imported/ig-food-kitsune.jpg',
  },
];
---

<div class="section-padding">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
    {eventTypes.map((event) => (
      <a
        href="#quote"
        class="event-type-card group relative block rounded-2xl overflow-hidden h-48 sm:h-52 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-gold"
        data-event-type={event.value}
      >
        <!-- Background Photo -->
        <img
          src={event.photo}
          alt={event.title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          loading="lazy"
        />
        <!-- Dark gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/50 to-brand-dark/20 group-hover:from-brand-dark/95 group-hover:via-brand-dark/60 transition-all duration-300"></div>

        <!-- Content -->
        <div class="relative z-10 h-full flex flex-col justify-end p-5">
          <div class="text-2xl mb-1" set:html={event.icon} />
          <h3 class="font-bold text-white text-lg mb-1 group-hover:text-brand-gold transition-colors duration-300">
            {event.title}
          </h3>
          <p class="text-sm text-gray-300 leading-snug">{event.subtitle}</p>
        </div>

        <!-- Hover arrow indicator -->
        <div class="absolute top-4 right-4 w-8 h-8 bg-brand-gold/0 group-hover:bg-brand-gold rounded-full flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</div>

<script>
  // When clicking an event type card, scroll to the form and pre-select the event type
  document.querySelectorAll<HTMLAnchorElement>('.event-type-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      const eventType = card.dataset.eventType;
      const select = document.getElementById('event-type') as HTMLSelectElement | null;

      if (select && eventType) {
        const options = select.options;
        for (let i = 0; i < options.length; i++) {
          if (options[i].value === eventType) {
            select.selectedIndex = i;
            break;
          }
        }
      }
    });
  });
</script>

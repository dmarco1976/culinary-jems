---
// Hardcoded fallback event — will be replaced with dynamic data later
const nextEvent = {
  name: 'Family Market at Radiance',
  date: 'Sat Mar 7',
  time: '4-7pm',
  location: 'Mesa',
  directionsUrl: 'https://www.google.com/maps/search/?api=1&query=Radiance+Mesa+AZ',
};
---

<section class="relative min-h-[80vh] md:min-h-[80vh] flex items-center bg-brand-dark overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img
      src="/assets/imported/hero.jpg"
      alt="Culinary JEMs gourmet sliders"
      class="w-full h-full object-cover scale-105"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/95 via-brand-dark/75 to-brand-dark/30"></div>
    <!-- Subtle radial glow behind the content -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_50%,rgba(255,197,89,0.08)_0%,transparent_60%)]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-8 lg:px-16 py-16 md:py-24 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Left Side: Text + CTAs -->
      <div>
        <img
          src="/assets/imported/ig-logo-circle.jpg"
          alt="Culinary JEMs - Gourmet Sliders"
          class="h-28 md:h-36 w-auto mb-6 drop-shadow-2xl rounded-full ring-4 ring-brand-gold/50 animate-fade-in-up"
        />
        <h1 class="heading-lg text-white leading-tight mb-4 animate-fade-in-up stagger-1">
          Chef-Driven Sliders.<br />
          <span class="text-brand-gold">Elevated Comfort Food.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-lg animate-fade-in-up stagger-2">
          Pop-ups, private parties &amp; catering across the East Valley
        </p>
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up stagger-3">
          <a href="/schedule" class="btn-primary rounded-lg text-center">
            Find Our Next Pop-Up
          </a>
          <a href="/catering" class="btn-pink rounded-lg text-center pulse-pink">
            Book Us for Your Event
          </a>
        </div>
      </div>

      <!-- Right Side: Next Event Card — Real Glassmorphism -->
      <div class="flex justify-center lg:justify-end animate-fade-in-up stagger-4">
        <div class="animate-float relative group">
          <!-- Glow behind card -->
          <div class="absolute -inset-1 bg-brand-gold/20 rounded-2xl blur-xl group-hover:bg-brand-gold/30 transition-all duration-500"></div>
          <div class="relative bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 md:p-8 max-w-sm w-full shadow-2xl">
            <!-- Subtle inner highlight -->
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/10 via-transparent to-transparent pointer-events-none"></div>
            <div class="relative z-10">
              <div class="inline-block bg-brand-gold text-brand-dark text-xs font-extrabold uppercase tracking-wider px-3 py-1 rounded-full mb-4">
                Next Pop-Up
              </div>
              <h3 class="text-white text-xl font-bold mb-2">{nextEvent.name}</h3>
              <div class="space-y-1 text-gray-300 text-sm mb-5">
                <p>
                  <span class="font-semibold text-white">{nextEvent.date}</span> &middot; {nextEvent.time}
                </p>
                <p>{nextEvent.location}</p>
              </div>
              <a
                href={nextEvent.directionsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-brand-gold font-semibold hover:underline text-sm group/link"
              >
                Get Directions
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade to blend with next section -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#FFF8E7] to-transparent"></div>
</section>

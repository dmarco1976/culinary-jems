---
const formUrl = import.meta.env.PUBLIC_CATERING_FORM_URL || '#';

const eventTypes = [
  'Corporate Lunch',
  'Private Party',
  'Brewery/Taproom',
  'Wedding/Celebration',
  'School/Community',
  'Other',
];
---

<section id="catering-form" class="section-padding">
  <div class="max-w-2xl mx-auto">
    <form
      id="catering-inquiry-form"
      class="space-y-6"
      data-action={formUrl}
      novalidate
    >
      <!-- Event Type -->
      <div>
        <label for="event-type" class="block text-sm font-semibold text-brand-dark mb-1">
          Event Type
        </label>
        <select
          id="event-type"
          name="eventType"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark bg-white focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
          required
        >
          <option value="" disabled selected>Select your event type</option>
          {eventTypes.map((type) => (
            <option value={type}>{type}</option>
          ))}
        </select>
      </div>

      <!-- Estimated Headcount -->
      <div>
        <label for="headcount" class="block text-sm font-semibold text-brand-dark mb-1">
          Estimated Headcount
        </label>
        <input
          type="number"
          id="headcount"
          name="headcount"
          min="10"
          placeholder="Minimum 10 guests"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
          required
        />
      </div>

      <!-- Preferred Date -->
      <div>
        <label for="preferred-date" class="block text-sm font-semibold text-brand-dark mb-1">
          Preferred Date
        </label>
        <input
          type="date"
          id="preferred-date"
          name="preferredDate"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
          required
        />
      </div>

      <!-- Location/Venue -->
      <div>
        <label for="location" class="block text-sm font-semibold text-brand-dark mb-1">
          Location / Venue
        </label>
        <input
          type="text"
          id="location"
          name="location"
          placeholder="Where is your event?"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
        />
      </div>

      <!-- Name -->
      <div>
        <label for="name" class="block text-sm font-semibold text-brand-dark mb-1">
          Name <span class="text-brand-pink">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Your full name"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
          required
        />
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-semibold text-brand-dark mb-1">
          Email <span class="text-brand-pink">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="you@email.com"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
          required
        />
      </div>

      <!-- Phone -->
      <div>
        <label for="phone" class="block text-sm font-semibold text-brand-dark mb-1">
          Phone
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="(555) 123-4567"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition"
        />
      </div>

      <!-- Additional Details -->
      <div>
        <label for="details" class="block text-sm font-semibold text-brand-dark mb-1">
          Additional Details
        </label>
        <textarea
          id="details"
          name="details"
          rows="4"
          placeholder="Tell us about your event — theme, dietary needs, anything special..."
          class="w-full border border-gray-300 rounded-lg px-4 py-3 text-brand-dark focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none transition resize-y"
        ></textarea>
      </div>

      <!-- Honeypot -->
      <div class="hidden" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Submit Button -->
      <div>
        <button
          type="submit"
          id="catering-submit-btn"
          class="btn-pink rounded-lg w-full text-lg"
        >
          Get Your Free Quote &rarr;
        </button>
      </div>

      <!-- Status Messages -->
      <div id="form-success" class="hidden bg-green-50 border border-green-300 text-green-800 rounded-lg p-4 text-center">
        <p class="font-semibold">Thank you! We'll get back to you within 24 hours.</p>
      </div>
      <div id="form-error" class="hidden bg-red-50 border border-red-300 text-red-800 rounded-lg p-4 text-center">
        <p class="font-semibold">
          Something went wrong. Please email us directly at
          <a href="mailto:culinaryjems@gmail.com" class="underline">culinaryjems@gmail.com</a>
        </p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('catering-inquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('catering-submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLDivElement;
  const errorMsg = document.getElementById('form-error') as HTMLDivElement;

  let isSubmitting = false;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Prevent double submit
    if (isSubmitting) return;

    // Client-side validation
    const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]');
    let isValid = true;

    requiredFields.forEach((field) => {
      if (!field.value.trim()) {
        field.classList.add('border-red-400');
        isValid = false;
      } else {
        field.classList.remove('border-red-400');
      }
    });

    // Validate email format
    const emailField = form.querySelector<HTMLInputElement>('#email');
    if (emailField && emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
      emailField.classList.add('border-red-400');
      isValid = false;
    }

    // Validate headcount min
    const headcountField = form.querySelector<HTMLInputElement>('#headcount');
    if (headcountField && headcountField.value && parseInt(headcountField.value) < 10) {
      headcountField.classList.add('border-red-400');
      isValid = false;
    }

    if (!isValid) {
      const firstInvalid = form.querySelector('.border-red-400') as HTMLElement;
      firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // Gather form data
    const formData = new FormData(form);
    const data: Record<string, string> = {};
    formData.forEach((value, key) => {
      data[key] = value.toString();
    });

    // Honeypot spam check
    if (data.website) {
      form.reset();
      successMsg.classList.remove('hidden');
      return;
    }

    const actionUrl = form.dataset.action || '#';
    if (!actionUrl || actionUrl === '#') {
      errorMsg.classList.remove('hidden');
      return;
    }

    // Loading state
    isSubmitting = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-60', 'cursor-not-allowed');

    // Hide previous messages
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      await fetch(actionUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({ ...data, formType: 'catering' }),
        mode: 'no-cors',
      });
      // GAS returns opaque response with no-cors — treat any non-thrown fetch as success
      form.reset();
      successMsg.classList.remove('hidden');
      form.querySelectorAll('input, select, textarea').forEach((f) => {
        (f as HTMLElement).classList.remove('border-red-400');
      });
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      isSubmitting = false;
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-60', 'cursor-not-allowed');
    }
  });

  // Remove red border on input
  form?.querySelectorAll('input, select, textarea').forEach((field) => {
    field.addEventListener('input', () => {
      field.classList.remove('border-red-400');
    });
  });
</script>

---
const quickLinks = [
  { label: 'Menu', href: '/menu' },
  { label: 'Catering', href: '/catering' },
  { label: 'Schedule', href: '/schedule' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-brand-dark text-white">
  <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-16 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      <!-- Column 1: Logo + Tagline -->
      <div>
        <a href="/" class="inline-block mb-3">
          <img src="/assets/imported/ig-logo-circle.jpg" alt="Culinary JEMs" class="h-16 w-auto rounded-full" />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Chef-Driven Sliders &amp; Elevated Comfort Food
        </p>
        <p class="text-gray-500 text-sm mt-4">
          Gilbert, AZ &middot; East Valley
        </p>
        <p class="text-gray-500 text-sm mt-1">
          <a href="mailto:culinaryjems@gmail.com" class="hover:text-brand-gold transition-colors">
            culinaryjems@gmail.com
          </a>
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-gray-300 hover:text-brand-gold transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Social Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-4">Follow Us</h3>
        <div class="flex items-center gap-4">
          <!-- Instagram -->
          <a
            href="https://instagram.com/culinaryjems"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-brand-gold transition-colors duration-200"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href="https://facebook.com/culinaryjems"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-brand-gold transition-colors duration-200"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>

          <!-- Yelp -->
          <a
            href="https://yelp.com/biz/culinary-jems"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-brand-gold transition-colors duration-200"
            aria-label="Yelp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308c.564-.83 1.956-.54 2.1.44l.528 3.065c.096.564-.276 1.044-.84 1.176l.478-.176zM13.254 14.74l4.8 2.1c.924.408.756 1.74-.252 1.932l-3.096.576c-.576.108-1.08-.264-1.176-.84l-.828-4.74c-.156-.96.984-1.524 1.644-.804l-1.092 1.776zm-1.14-2.388l-3.528-3.528c-.72-.72-.216-1.932.768-1.836l3.12.288c.564.048.96.504.948 1.068l-.12 4.968c-.024.984-1.356 1.308-1.848.492l.66-1.452zm-3.108 3.78l-.276 4.992c-.048.996-1.404 1.272-1.884.384l-1.572-2.844c-.276-.504-.084-1.116.42-1.404l4.236-2.58c.84-.504 1.668.576 1.02 1.308l.056.144zM9.174 9.246l-4.284-2.46c-.876-.504-.576-1.848.444-1.98l3.108-.396c.576-.072 1.08.312 1.2.876l.888 4.728c.168.96-.888 1.584-1.596.876l.24-1.644z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 mt-10 pt-6 text-center">
      <p class="text-gray-500 text-sm">
        &copy; 2026 Culinary JEMs. All rights reserved.
      </p>
    </div>
  </div>
</footer>

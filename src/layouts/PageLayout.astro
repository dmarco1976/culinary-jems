---
import BaseLayout from './BaseLayout.astro';
import NextEventBanner from '../components/NextEventBanner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
}

const { title, description, ogImage, schema } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} schema={schema}>
  <NextEventBanner />
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>

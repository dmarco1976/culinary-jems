---
import PageLayout from '../layouts/PageLayout.astro';

const formUrl = import.meta.env.PUBLIC_CATERING_FORM_URL || '#';
---

<PageLayout
  title="Contact | Culinary JEMs — Get in Touch"
  description="Contact Culinary JEMs for questions, feedback, or general inquiries. For catering requests, visit our dedicated catering page."
>
  <section class="section-padding">
    <div class="max-w-2xl mx-auto">
      <h1 class="heading-lg mb-4 text-center">Get in Touch</h1>
      <p class="text-lg text-gray-600 text-center mb-4">
        Have a question or want to say hello? We'd love to hear from you.
      </p>
      <p class="text-center mb-12">
        <strong>Looking to book us for an event?</strong>
        <a href="/catering" class="text-brand-pink hover:underline font-semibold">
          Visit our Catering page →
        </a>
      </p>

      <!-- Contact Info -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-brand-light rounded-lg p-6">
          <h2 class="font-bold text-lg mb-4">Contact Info</h2>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 text-brand-pink shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:culinaryjems@gmail.com" class="hover:text-brand-pink">culinaryjems@gmail.com</a>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 text-brand-pink shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>Gilbert, AZ · Serving the East Valley</span>
            </li>
          </ul>
        </div>
        <div class="bg-brand-light rounded-lg p-6">
          <h2 class="font-bold text-lg mb-4">Follow Us</h2>
          <ul class="space-y-3 text-gray-700">
            <li>
              <a
                href="https://instagram.com/culinaryjems"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-brand-pink flex items-center gap-2"
              >
                Instagram @culinaryjems
              </a>
            </li>
            <li>
              <a
                href="https://facebook.com/culinaryjems"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-brand-pink flex items-center gap-2"
              >
                Facebook
              </a>
            </li>
            <li>
              <a
                href="https://yelp.com/biz/culinary-jems-gilbert"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-brand-pink flex items-center gap-2"
              >
                Yelp · 4.0 ★ · 241 reviews
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- General Contact Form -->
      <div class="bg-white border border-gray-200 rounded-lg p-8">
        <h2 class="heading-sm mb-6">Send Us a Message</h2>
        <form id="contact-form" class="space-y-6" data-action={formUrl}>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="contact-name" class="block text-sm font-semibold mb-2">Name *</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-semibold mb-2">Email *</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none"
                placeholder="your@email.com"
              />
            </div>
          </div>
          <div>
            <label for="contact-subject" class="block text-sm font-semibold mb-2">Subject</label>
            <input
              type="text"
              id="contact-subject"
              name="subject"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none"
              placeholder="What's this about?"
            />
          </div>
          <div>
            <label for="contact-message" class="block text-sm font-semibold mb-2">Message *</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-gold focus:border-brand-gold outline-none resize-y"
              placeholder="Tell us what's on your mind..."
            ></textarea>
          </div>
          <div class="hidden" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <button
            type="submit"
            class="btn-primary w-full md:w-auto"
          >
            Send Message
          </button>
        </form>

        <div id="contact-success" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800">
          Thanks for reaching out! We'll get back to you soon.
        </div>
        <div id="contact-error" class="hidden mt-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800">
          Something went wrong. Please email us directly at <a href="mailto:culinaryjems@gmail.com" class="underline">culinaryjems@gmail.com</a>.
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('contact-success')!;
  const errorEl = document.getElementById('contact-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = btn.textContent;
    btn.textContent = 'Sending...';
    btn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Honeypot spam check
    if (data.website) {
      form.classList.add('hidden');
      successEl.classList.remove('hidden');
      return;
    }

    const actionUrl = form.dataset.action || '#';
    if (!actionUrl || actionUrl === '#') {
      errorEl.classList.remove('hidden');
      btn.textContent = originalText;
      btn.disabled = false;
      return;
    }

    try {
      await fetch(actionUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({ ...data, formType: 'contact' }),
        mode: 'no-cors',
      });
      // GAS returns opaque response with no-cors — treat any non-thrown fetch as success
      form.classList.add('hidden');
      successEl.classList.remove('hidden');
    } catch {
      errorEl.classList.remove('hidden');
    } finally {
      btn.textContent = originalText;
      btn.disabled = false;
    }
  });
</script>
